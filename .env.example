# ============================================================
# Indian Budget RAG — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit it to version control.

# ---------------------------------------------------------------------------
# Qdrant Vector Database
# ---------------------------------------------------------------------------

# URL of your Qdrant instance.
# Local Docker:  http://localhost:6333
# Qdrant Cloud:  https://<cluster-id>.<region>.cloud.qdrant.io
QDRANT_URL=http://localhost:6333

# API key — required for Qdrant Cloud, leave blank for local.
QDRANT_API_KEY=

# Name of the collection to create / upsert into.
QDRANT_COLLECTION=indian_budget_2026

# Similarity metric: Cosine | Dot | Euclid
QDRANT_DISTANCE=Cosine

# ---------------------------------------------------------------------------
# Embedding Model
# ---------------------------------------------------------------------------

# HuggingFace model name (must be compatible with sentence-transformers).
# EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Force a specific device: cpu | cuda | mps
# EMBEDDING_DEVICE=cpu

# ---------------------------------------------------------------------------
# LLM (Groq)
# ---------------------------------------------------------------------------

# Groq API key — required for LLM generation
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# API Configuration
# ---------------------------------------------------------------------------

# API prefix for versioning
API_PREFIX=/api/v1

# Host and port for the API server
API_HOST=0.0.0.0
API_PORT=8000

# Debug mode (enables auto-reload and detailed logging)
DEBUG=false

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Require API key authentication
REQUIRE_AUTH=false

# ---------------------------------------------------------------------------
# Reranking
# ---------------------------------------------------------------------------

# Enable reranking by default
ENABLE_RERANKING=false

# Reranker model (sentence-transformers cross-encoder)
RERANKER_MODEL=ms-marco-MiniLM-L-6-v2

# Reranker device
RERANKER_DEVICE=cpu

# Retrieval configuration
RETRIEVE_TOP_K=20
RERANK_TOP_K=20
RETURN_TOP_K=5

# ---------------------------------------------------------------------------
# RAG Pipeline
# ---------------------------------------------------------------------------

# Context configuration
CONTEXT_MAX_TOKENS=4000
INCLUDE_CITATIONS=true
PROMPT_TEMPLATE=qa

# LLM configuration
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ---------------------------------------------------------------------------
# Evaluation
# ---------------------------------------------------------------------------

# Output directories
EVALUATION_OUTPUT_DIR=evaluation/reports
EVALUATION_EXPERIMENT_DIR=evaluation/experiments

# ---------------------------------------------------------------------------
# OpenTelemetry Observability
# ---------------------------------------------------------------------------

# Service name for observability
OTEL_SERVICE_NAME=indian-budget-rag

# Service version
OTEL_SERVICE_VERSION=1.0.0

# Deployment environment (development, staging, production)
OTEL_ENVIRONMENT=development

# Sampling ratio for production (0.0 to 1.0)
# Development uses 100% sampling automatically
OTEL_SAMPLING_RATIO=0.1

# OTLP endpoint for exporting traces and metrics
# Local development: http://localhost:4317
# Production: your observability backend endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Exporter types (otlp, console)
# Development uses console, production uses otlp
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
