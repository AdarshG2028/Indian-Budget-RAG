# ============================================================
# Indian Budget RAG — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit it to version control.

# ---------------------------------------------------------------------------
# Qdrant Vector Database
# ---------------------------------------------------------------------------

# URL of your Qdrant instance.
# Local Docker:  http://localhost:6333
# Qdrant Cloud:  https://<cluster-id>.<region>.cloud.qdrant.io
QDRANT_URL=http://localhost:6333

# API key — required for Qdrant Cloud, leave blank for local.
QDRANT_API_KEY=

# Name of the collection to create / upsert into.
QDRANT_COLLECTION=indian_budget_2026

# Similarity metric: Cosine | Dot | Euclid
QDRANT_DISTANCE=Cosine

# ---------------------------------------------------------------------------
# Embedding Model
# ---------------------------------------------------------------------------

# HuggingFace model name (must be compatible with sentence-transformers).
# EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Force a specific device: cpu | cuda | mps
# EMBEDDING_DEVICE=cpu
